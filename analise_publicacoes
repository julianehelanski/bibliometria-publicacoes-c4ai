def parse_args():
    parser = argparse.ArgumentParser(
        description="Análise de publicações do C4AI (USP)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--input",    default=DEFAULT_INPUT,  help="Arquivo Excel de entrada")
    parser.add_argument("--output",   default=DEFAULT_OUTPUT, help="Pasta de saída")
    parser.add_argument("--no-plots", action="store_true",    help="Não gerar visualizações")
    return parser.parse_args()


def main():
    args = parse_args()

    input_path = Path(args.input)
    if not input_path.exists():
        print(f"[ERRO] Arquivo não encontrado: {input_path}", file=sys.stderr)
        sys.exit(1)

    outdir = Path(args.output)
    outdir.mkdir(parents=True, exist_ok=True)

    configure_plots()

    # ── Carregamento ──────────────────────────────────────────────────────────
    print(f"\nCarregando dados de: {input_path}")
    df = load_data(str(input_path))
    print(f"  {len(df)} publicações · {df['Grupo'].nunique()} grupos · "
          f"{df['Ano'].min()}–{df['Ano'].max()}")

    # ── Estatísticas ─────────────────────────────────────────────────────────
    grupos_dist   = df["Grupo"].value_counts().sort_values(ascending=False)
    produtividade = compute_group_stats(df)
    pub_ano       = df["Ano"].value_counts().sort_index()

    print_summary(df, grupos_dist, produtividade)

    # ── Visualizações ─────────────────────────────────────────────────────────
    if not args.no_plots:
        print(f"\nGerando gráficos em: {outdir}/")
        plot_ranking(grupos_dist, len(df), outdir)
        plot_pie(grupos_dist, outdir)
        plot_temporal(pub_ano, outdir)
        plot_heatmap(df, outdir)
        plot_all_groups_lines(df, grupos_dist, outdir)
        plot_productivity(produtividade, outdir)
        plot_top_groups(df, grupos_dist, outdir)
        plot_stacked(df, grupos_dist, outdir)
        plot_concentration(grupos_dist, outdir)

    # ── Exportação ────────────────────────────────────────────────────────────
    print(f"\nExportando tabelas e relatório em: {outdir}/")
    export_tables(df, produtividade, grupos_dist, outdir)
    export_report(df, grupos_dist, produtividade, outdir)

    print("\nAnálise concluída.\n")


if __name__ == "__main__":
    main()
