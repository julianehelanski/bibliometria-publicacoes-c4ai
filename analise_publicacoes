def load_data(filepath: str) -> pd.DataFrame:
    """Lê todas as planilhas do Excel e consolida em um único DataFrame limpo."""
    xl = pd.ExcelFile(filepath)
    frames = []

    for sheet in xl.sheet_names:
        df = pd.read_excel(filepath, sheet_name=sheet)
        df.columns = df.columns.str.strip()

        # Renomear colunas para nomes canônicos
        col_map = {}
        for col in df.columns:
            cl = col.lower()
            if "grupo" in cl:
                col_map[col] = "Grupo"
            elif "data" in cl or "ano" in cl:
                col_map[col] = "Ano"
            elif "título" in cl or "titulo" in cl or "tulo" in cl:
                col_map[col] = "Titulo"
        df.rename(columns=col_map, inplace=True)

        if "Tipo_Publicacao" not in df.columns:
            df["Tipo_Publicacao"] = "Publicação"

        if "Grupo" in df.columns:
            frames.append(df)

    df = pd.concat(frames, ignore_index=True)

    # Limpeza
    df = df[~df["Grupo"].isin(["Grupo de Pesquisa"])]
    df = df[df["Ano"] != "Data de publicação"]
    df["Ano"] = pd.to_numeric(df["Ano"], errors="coerce")
    df.dropna(subset=["Ano"], inplace=True)
    df["Ano"] = df["Ano"].astype(int)
    df = df[(df["Ano"] >= 2000) & (df["Ano"] <= 2025)]

    return df


# ──────────────────────────────────────────────────────────────────────────────
# 2. ESTATÍSTICAS
# ──────────────────────────────────────────────────────────────────────────────

def compute_group_stats(df: pd.DataFrame) -> pd.DataFrame:
    """Calcula métricas de produtividade por grupo."""
    rows = []
    for grupo, sub in df.groupby("Grupo"):
        primeiro, ultimo = sub["Ano"].min(), sub["Ano"].max()
        anos_ativos = ultimo - primeiro + 1
        total = len(sub)
        taxa = total / anos_ativos

        media_autores = (
            sub["Autores"]
            .apply(lambda x: len(str(x).split(";")) if pd.notna(x) else 1)
            .mean()
            if "Autores" in sub.columns
            else np.nan
        )

        rows.append({
            "Grupo":               grupo,
            "Total_Publicacoes":   total,
            "Primeiro_Ano":        primeiro,
            "Ultimo_Ano":          ultimo,
            "Anos_Ativos":         anos_ativos,
            "Publicacoes_por_Ano": round(taxa, 2),
            "Media_Autores":       round(media_autores, 2) if not np.isnan(media_autores) else 0,
        })

    return pd.DataFrame(rows).sort_values("Publicacoes_por_Ano", ascending=False)


def compute_hhi(series: pd.Series) -> float:
    shares = series / series.sum()
    return (shares ** 2).sum() * 10_000


