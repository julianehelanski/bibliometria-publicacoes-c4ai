def plot_stacked(df: pd.DataFrame, grupos_dist: pd.Series, outdir: Path):
    anos = sorted(df["Ano"].unique())
    cores = sns.color_palette("Spectral", n_colors=len(grupos_dist))
    fig, ax = plt.subplots(figsize=(16, 10))
    bottom = np.zeros(len(anos))

    for i, grupo in enumerate(grupos_dist.index):
        vals = [len(df[(df["Grupo"] == grupo) & (df["Ano"] == a)]) for a in anos]
        ax.bar(anos, vals, bottom=bottom, label=grupo, color=cores[i], edgecolor="white", linewidth=0.5)
        bottom += np.array(vals, dtype=float)

    ax.set(xlabel="Ano", ylabel="Número de Publicações")
    ax.legend(title="Grupo de Pesquisa", bbox_to_anchor=(1.05, 1), loc="upper left", fontsize=10)
    ax.grid(axis="y", alpha=0.3)
    plt.tight_layout()
    save(fig, outdir, "8_composicao_temporal.png")


def plot_concentration(grupos_dist: pd.Series, outdir: Path):
    cores = sns.color_palette("Spectral", n_colors=len(grupos_dist))
    participacao = (grupos_dist / grupos_dist.sum() * 100).sort_values(ascending=False)
    participacao_acum = participacao.cumsum()

    ordered = grupos_dist.sort_values(ascending=False)
    freq_acum = ordered.cumsum() / ordered.sum() * 100
    grupos_acum = np.arange(1, len(ordered) + 1) / len(ordered) * 100

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(18, 7))

    ax1.plot(grupos_acum, freq_acum, marker="o", linewidth=2.5, markersize=8, color="#E74C3C", label="Curva de Lorenz")
    ax1.plot([0, 100], [0, 100], "--", color="gray", linewidth=2, alpha=0.7, label="Igualdade Perfeita")
    ax1.fill_between(grupos_acum, freq_acum, grupos_acum, alpha=0.3, color="#E74C3C")
    ax1.set(xlabel="% Acumulada de Grupos", ylabel="% Acumulada de Publicações")
    ax1.legend(fontsize=11)
    ax1.grid(True, alpha=0.3)

    ax2.bar(range(len(participacao)), participacao.values, color=cores, edgecolor="black", linewidth=1)
    ax2.plot(range(len(participacao_acum)), participacao_acum.values,
             marker="o", color="red", linewidth=2.5, markersize=8, label="% Acumulada")
    ax2.axhline(y=80, color="green", linestyle="--", linewidth=2, alpha=0.7, label="80% das publicações")
    ax2.set_xticks(range(len(participacao)))
    ax2.set_xticklabels(participacao.index, rotation=45, ha="right")
    ax2.set(ylabel="Participação (%)")
    ax2.legend(fontsize=11)
    ax2.grid(axis="y", alpha=0.3)
    for i, (v, _) in enumerate(zip(participacao.values, participacao_acum.values)):
        ax2.text(i, v + 0.5, f"{v:.1f}%", ha="center", va="bottom", fontsize=8, fontweight="bold")

    plt.tight_layout()
    save(fig, outdir, "9_analise_concentracao.png")


