def save(fig, outdir: Path, filename: str):
    path = outdir / filename
    fig.savefig(path, dpi=300, bbox_inches="tight")
    plt.close(fig)
    print(f"  ✓  {path}")


def plot_ranking(grupos_dist: pd.Series, total: int, outdir: Path):
    # Dot plot de Cleveland (menor embaixo); rótulo = nº (pct%).
    serie = grupos_dist.sort_values(ascending=True)
    labels = list(serie.index)
    vals = list(serie.values)
    rot = [f"{num_ptbr(v)} ({pct_ptbr(v / total * 100)}%)" for v in vals]
    fig, ax = plt.subplots(figsize=(13, 8))
    dotplot(ax, labels, vals, COR_SERIE, rotulos=rot)
    ax.set_xlabel("publicações no período", fontsize=9, color=_TXT_FRACO)
    nota_rodape(ax, f"Publicações por grupo de pesquisa do C4AI · N = {num_ptbr(total)}.")
    plt.tight_layout()
    save(fig, outdir, "1_ranking_grupos.png")


