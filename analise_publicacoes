def plot_temporal(pub_ano: pd.Series, outdir: Path):
    # Série temporal como linha com bolinhas (sem painel de barras).
    fig, ax = plt.subplots(figsize=(12, 6))
    x = list(pub_ano.index)
    y = list(pub_ano.values)
    linha_bolinha(ax, x, y, COR_SERIE)
    z = np.polyfit(x, y, 1)
    ax.plot(x, np.poly1d(z)(x), "--", color=_TXT_FRACO, linewidth=1.4,
            alpha=0.8, zorder=1, label="tendência linear")
    ax.set_xlabel("ano", fontsize=9, color=_TXT_FRACO)
    ax.set_ylabel("publicações", fontsize=9, color=_TXT_FRACO)
    ax.set_xticks(x)
    ax.set_ylim(0, max(y) * 1.18)
    eixo_ptbr(ax, "y")
    ax.legend(loc="upper left", frameon=False, fontsize=9)
    nota_rodape(ax, "Evolução anual das publicações do C4AI; linha tracejada = tendência linear.")
    plt.tight_layout()
    save(fig, outdir, "3_evolucao_temporal_geral.png")


