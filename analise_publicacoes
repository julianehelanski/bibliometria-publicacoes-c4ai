def print_summary(df: pd.DataFrame, grupos_dist: pd.Series, produtividade: pd.DataFrame):
    pub_ano = df["Ano"].value_counts().sort_index()
    total = len(df)
    hhi = compute_hhi(grupos_dist)
    top3_pct = grupos_dist.head(3).sum() / total * 100

    sep = "=" * 80
    print(f"\n{sep}")
    print("RESUMO EXECUTIVO — C4AI")
    print(sep)
    print(f"  Total de publicações : {total}")
    print(f"  Período              : {df['Ano'].min()}–{df['Ano'].max()}")
    print(f"  Grupos ativos        : {df['Grupo'].nunique()}")
    print(f"  Ano mais produtivo   : {pub_ano.idxmax()} ({pub_ano.max()} pubs)")
    print(f"  Grupo top (total)    : {grupos_dist.index[0]} ({grupos_dist.iloc[0]} pubs)")
    print(f"  Grupo top (pubs/ano) : {produtividade.iloc[0]['Grupo']} "
          f"({produtividade.iloc[0]['Publicacoes_por_Ano']:.2f} pubs/ano)")
    print(f"  Top 3 concentram     : {top3_pct:.1f}%")
    print(f"  HHI                  : {hhi:.0f} "
          f"({'Descentralizado' if hhi < 1500 else 'Moderado' if hhi < 2500 else 'Concentrado'})")

    print(f"\n{'Pos':<5} {'Grupo':<22} {'Total':<8} {'Pubs/Ano':<10} {'Período'}")
    print("-" * 65)
    for i, (grupo, count) in enumerate(grupos_dist.items(), 1):
        taxa = produtividade.loc[produtividade["Grupo"] == grupo, "Publicacoes_por_Ano"].values[0]
        prim = produtividade.loc[produtividade["Grupo"] == grupo, "Primeiro_Ano"].values[0]
        ulti = produtividade.loc[produtividade["Grupo"] == grupo, "Ultimo_Ano"].values[0]
        print(f"{i:<5} {grupo:<22} {count:<8} {taxa:<10.2f} {int(prim)}–{int(ulti)}")
    print(sep)


