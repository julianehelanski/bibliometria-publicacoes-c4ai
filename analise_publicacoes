def export_tables(df: pd.DataFrame, produtividade: pd.DataFrame,
                  grupos_dist: pd.Series, outdir: Path):
    """Exporta planilhas e relatório executivo."""
    df.to_excel(outdir / "c4ai_dados_completos_limpo.xlsx", index=False)
    print(f"  ✓  {outdir / 'c4ai_dados_completos_limpo.xlsx'}")

    produtividade.to_excel(outdir / "c4ai_produtividade_todos_grupos.xlsx", index=False)
    print(f"  ✓  {outdir / 'c4ai_produtividade_todos_grupos.xlsx'}")

    pd.crosstab(df["Grupo"], df["Ano"], margins=True).to_excel(outdir / "c4ai_matriz_grupo_ano.xlsx")
    print(f"  ✓  {outdir / 'c4ai_matriz_grupo_ano.xlsx'}")

    total = len(df)
    resumo = pd.DataFrame({
        "Grupo":               grupos_dist.index,
        "Total_Publicacoes":   grupos_dist.values,
        "Percentual":          [v / total * 100 for v in grupos_dist.values],
        "Ranking":             range(1, len(grupos_dist) + 1),
    })
    resumo.to_excel(outdir / "c4ai_resumo_grupos.xlsx", index=False)
    print(f"  ✓  {outdir / 'c4ai_resumo_grupos.xlsx'}")


def export_report(df: pd.DataFrame, grupos_dist: pd.Series,
                  produtividade: pd.DataFrame, outdir: Path):
    pub_ano = df["Ano"].value_counts().sort_index()
    total = len(df)
    hhi = compute_hhi(grupos_dist)
    top3_pct = grupos_dist.head(3).sum() / total * 100
    anos_periodo = df["Ano"].max() - df["Ano"].min() + 1

    lines = [
        "=" * 80,
        "RELATÓRIO EXECUTIVO — ANÁLISE DE PUBLICAÇÕES DO C4AI",
        "=" * 80,
        f"Data da análise : {pd.Timestamp.now().strftime('%d/%m/%Y %H:%M')}",
        f"Total de publicações : {total}",
        f"Período : {df['Ano'].min()}–{df['Ano'].max()}",
        f"Grupos de pesquisa : {df['Grupo'].nunique()}",
        "",
        "RANKING DE GRUPOS",
        "-" * 80,
    ]
    for i, (grupo, count) in enumerate(grupos_dist.items(), 1):
        lines.append(f"{i:2d}. {grupo:25s}: {count:3d} publicações ({count/total*100:5.1f}%)")

    lines += [
        "",
        "INDICADORES GERAIS",
        "-" * 80,
        f"Média geral : {total/anos_periodo:.1f} publicações/ano",
        f"Grupo mais produtivo (total) : {grupos_dist.index[0]} ({grupos_dist.iloc[0]} pubs)",
        f"Grupo mais eficiente (pubs/ano) : {produtividade.iloc[0]['Grupo']} "
        f"({produtividade.iloc[0]['Publicacoes_por_Ano']:.2f} pubs/ano)",
        f"Ano mais produtivo : {pub_ano.idxmax()} ({pub_ano.max()} publicações)",
        f"Top 3 concentram : {top3_pct:.1f}% das publicações",
        f"Índice HHI : {hhi:.0f} "
        f"({'Descentralizado' if hhi < 1500 else 'Moderado' if hhi < 2500 else 'Concentrado'})",
        "=" * 80,
    ]

    path = outdir / "c4ai_relatorio_executivo.txt"
    path.write_text("\n".join(lines), encoding="utf-8")
    print(f"  ✓  {path}")


