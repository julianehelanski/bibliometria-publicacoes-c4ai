def plot_stacked(df: pd.DataFrame, grupos_dist: pd.Series, outdir: Path):
    # Barras empilhadas -> uma linha com bolinhas por grupo, total no topo.
    anos = sorted(df["Ano"].unique())
    grupos = list(grupos_dist.index)
    cores = cor_categorica(len(grupos))
    fig, ax = plt.subplots(figsize=(15, 9))
    totais = [len(df[df["Ano"] == a]) for a in anos]
    gmax = 1
    for i, grupo in enumerate(grupos):
        vals = [len(df[(df["Grupo"] == grupo) & (df["Ano"] == a)]) for a in anos]
        gmax = max(gmax, max(vals))
        ax.plot(anos, vals, color=cores[i], linewidth=2, zorder=2, label=grupo)
        ax.scatter(anos, vals, s=90, color=cores[i], edgecolors="white",
                   linewidths=1.2, zorder=3)
    # Total do ano em cinza, numa faixa-cabeçalho acima das linhas (a escala
    # do eixo segue o máximo por grupo, não o total, para não esvaziar a área).
    y_tot = gmax * 1.16
    for a, tot in zip(anos, totais):
        ax.annotate(num_ptbr(tot), xy=(a, y_tot), ha="center", fontsize=8.5,
                    color=_TXT_FRACO)
    ax.text(anos[0], gmax * 1.24, "total no ano:", fontsize=8, style="italic",
            color=_TXT_FRACO)
    ax.set_xlabel("ano", fontsize=9, color=_TXT_FRACO)
    ax.set_ylabel("publicações", fontsize=9, color=_TXT_FRACO)
    ax.set_xticks(anos)
    ax.set_ylim(0, gmax * 1.30)
    for sp in ("top", "right"):
        ax.spines[sp].set_visible(False)
    ax.grid(axis="y", linestyle=":", linewidth=0.6, color="#e3e3e3", zorder=0)
    ax.legend(loc="center left", bbox_to_anchor=(1.01, 0.5), frameon=False,
              fontsize=9, handlelength=1.4)
    nota_rodape(ax, "Composição anual por grupo; o total do ano aparece em cinza no topo.")
    plt.tight_layout()
    save(fig, outdir, "8_composicao_temporal.png")


def plot_concentration(grupos_dist: pd.Series, outdir: Path):
    participacao = (grupos_dist / grupos_dist.sum() * 100).sort_values(ascending=False)
    ordered = grupos_dist.sort_values(ascending=False)
    freq_acum = (ordered.cumsum() / ordered.sum() * 100).values
    grupos_acum = (np.arange(1, len(ordered) + 1) / len(ordered) * 100)

    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(17, 7))

    # Lorenz: curva com bolinhas + diagonal de igualdade.
    gx = [0.0] + list(grupos_acum)
    gy = [0.0] + list(freq_acum)
    ax1.plot([0, 100], [0, 100], "--", color=_TXT_FRACO, linewidth=1.4,
             alpha=0.8, zorder=1, label="igualdade perfeita")
    ax1.plot(gx, gy, color=COR_SERIE, linewidth=2, zorder=2, label="curva de Lorenz")
    ax1.scatter(gx[1:], gy[1:], s=90, color=COR_SERIE, edgecolors="white",
                linewidths=1.2, zorder=3)
    ax1.fill_between(gx, gy, gx, alpha=0.12, color=COR_SERIE, zorder=0)
    ax1.set_xlabel("% acumulada de grupos", fontsize=9, color=_TXT_FRACO)
    ax1.set_ylabel("% acumulada de publicações", fontsize=9, color=_TXT_FRACO)
    ax1.legend(loc="upper left", frameon=False, fontsize=9)
    for sp in ("top", "right"):
        ax1.spines[sp].set_visible(False)
    ax1.grid(True, linestyle=":", linewidth=0.6, color="#e3e3e3", zorder=0)

    # Participação por grupo: dot plot (do menor para o maior).
    part = participacao.sort_values(ascending=True)
    labels = list(part.index)
    vals = list(part.values)
    rot = [f"{pct_ptbr(v)}%" for v in vals]
    dotplot(ax2, labels, vals, COR_SERIE, rotulos=rot)
    ax2.set_xlabel("participação no total (%)", fontsize=9, color=_TXT_FRACO)
    nota_rodape(ax1, "Concentração da produção entre os grupos: curva de Lorenz (esq.) e participação por grupo (dir.).")
    plt.tight_layout()
    save(fig, outdir, "9_analise_concentracao.png")


