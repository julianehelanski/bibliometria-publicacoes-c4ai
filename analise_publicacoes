    crosstab = pd.crosstab(df["Grupo"], df["Ano"])
    fig, ax = plt.subplots(figsize=(14, 9))
    sns.heatmap(
        crosstab, annot=True, fmt="d", cmap=CMAP_SEQUENCIAL,
        cbar_kws={"label": "publicações"},
        linewidths=0.5, linecolor="white", ax=ax,
        annot_kws={"fontsize": 8, "color": "#333333"},
    )
    ax.set_xlabel("ano", fontsize=9, color=_TXT_FRACO)
    ax.set_ylabel("grupo de pesquisa", fontsize=9, color=_TXT_FRACO)
    ax.tick_params(labelsize=9)
    plt.tight_layout()
    save(fig, outdir, "4_heatmap_grupo_ano.png")


