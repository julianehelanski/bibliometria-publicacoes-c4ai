def load_data(filepath: str) -> pd.DataFrame:
    """Lê todas as planilhas do Excel e consolida em um único DataFrame limpo."""
    xl = pd.ExcelFile(filepath)
    frames = []

    for sheet in xl.sheet_names:
        df = pd.read_excel(filepath, sheet_name=sheet)
        df.columns = df.columns.str.strip()

        # Renomear colunas para nomes canônicos
        col_map = {}
        for col in df.columns:
            cl = col.lower()
            if "grupo" in cl:
                col_map[col] = "Grupo"
            elif "data" in cl or "ano" in cl:
                col_map[col] = "Ano"
            elif "título" in cl or "titulo" in cl or "tulo" in cl:
                col_map[col] = "Titulo"
        df.rename(columns=col_map, inplace=True)

        if "Tipo_Publicacao" not in df.columns:
            df["Tipo_Publicacao"] = "Publicação"

        if "Grupo" in df.columns:
            frames.append(df)

    df = pd.concat(frames, ignore_index=True)

    # Limpeza
    df = df[~df["Grupo"].isin(["Grupo de Pesquisa"])]
    df = df[df["Ano"] != "Data de publicação"]
    df["Ano"] = pd.to_numeric(df["Ano"], errors="coerce")
    df.dropna(subset=["Ano"], inplace=True)
    df["Ano"] = df["Ano"].astype(int)
    df = df[(df["Ano"] >= 2000) & (df["Ano"] <= 2025)]

    return df


