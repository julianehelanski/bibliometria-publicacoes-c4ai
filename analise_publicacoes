def save(fig, outdir: Path, filename: str):
    path = outdir / filename
    fig.savefig(path, dpi=300, bbox_inches="tight")
    plt.close(fig)
    print(f"  ✓  {path}")


def plot_ranking(grupos_dist: pd.Series, total: int, outdir: Path):
    cores = sns.color_palette("Spectral", n_colors=len(grupos_dist))
    fig, ax = plt.subplots(figsize=(14, 8))

    ax.barh(range(len(grupos_dist)), grupos_dist.values, color=cores)
    ax.set_yticks(range(len(grupos_dist)))
    ax.set_yticklabels(grupos_dist.index)
    ax.set_xlabel("Número de Publicações", fontweight="bold")
    ax.grid(axis="x", alpha=0.3)
    ax.invert_yaxis()

    for i, v in enumerate(grupos_dist.values):
        ax.text(v + 0.5, i, f"{v} ({v/total*100:.1f}%)", va="center", fontweight="bold", fontsize=10)

    plt.tight_layout()
    save(fig, outdir, "1_ranking_grupos.png")


def plot_pie(grupos_dist: pd.Series, outdir: Path):
    cores = sns.color_palette("Spectral", n_colors=len(grupos_dist))
    fig, ax = plt.subplots(figsize=(12, 12))

    wedges, texts, autotexts = ax.pie(
        grupos_dist.values,
        labels=grupos_dist.index,
        autopct="%1.1f%%",
        startangle=90,
        colors=cores,
        textprops={"fontsize": 11, "fontweight": "bold"},
    )
    for at in autotexts:
        at.set_color("white")
        at.set_fontsize(10)
        at.set_fontweight("bold")

    plt.tight_layout()
    save(fig, outdir, "2_pizza_grupos.png")


def plot_temporal(pub_ano: pd.Series, outdir: Path):
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))

    bars = ax1.bar(pub_ano.index, pub_ano.values, color="#2E86AB", edgecolor="black", linewidth=1.5)
    ano_max = pub_ano.idxmax()
    bars[list(pub_ano.index).index(ano_max)].set_color("#E74C3C")
    for ano, val in pub_ano.items():
        ax1.text(ano, val + 0.5, str(val), ha="center", va="bottom", fontweight="bold", fontsize=10)
    ax1.set(xlabel="Ano", ylabel="Número de Publicações")
    ax1.grid(axis="y", alpha=0.3)

    ax2.plot(pub_ano.index, pub_ano.values, marker="o", linewidth=3, markersize=10, color="#9B59B6", label="Publicações")
    ax2.fill_between(pub_ano.index, pub_ano.values, alpha=0.3, color="#9B59B6")
    z = np.polyfit(pub_ano.index, pub_ano.values, 1)
    ax2.plot(pub_ano.index, np.poly1d(z)(pub_ano.index), "--", color="red", linewidth=2, alpha=0.7, label="Tendência Linear")
    ax2.set(xlabel="Ano", ylabel="Número de Publicações")
    ax2.legend(fontsize=11)
    ax2.grid(True, alpha=0.3)

    plt.tight_layout()
    save(fig, outdir, "3_evolucao_temporal_geral.png")


def plot_heatmap(df: pd.DataFrame, outdir: Path):
    crosstab = pd.crosstab(df["Grupo"], df["Ano"])
    fig, ax = plt.subplots(figsize=(16, 10))
    sns.heatmap(
        crosstab, annot=True, fmt="d", cmap="YlOrRd",
        cbar_kws={"label": "Número de Publicações"},
        linewidths=0.5, linecolor="gray", ax=ax,
    )
    ax.set(xlabel="Ano", ylabel="Grupo de Pesquisa")
    plt.tight_layout()
    save(fig, outdir, "4_heatmap_grupo_ano.png")


def plot_all_groups_lines(df: pd.DataFrame, grupos_dist: pd.Series, outdir: Path):
    cores = sns.color_palette("tab10", n_colors=len(grupos_dist))
    fig, ax = plt.subplots(figsize=(16, 10))

    for i, grupo in enumerate(grupos_dist.index):
        sub = df[df["Grupo"] == grupo]
        serie = sub["Ano"].value_counts().sort_index()
        ax.plot(serie.index, serie.values, marker="o", linewidth=2.5, markersize=8, label=grupo, color=cores[i])

    ax.set(xlabel="Ano", ylabel="Número de Publicações")
    ax.legend(title="Grupo de Pesquisa", fontsize=10, title_fontsize=11, loc="upper left", framealpha=0.9)
    ax.grid(True, alpha=0.3)
    plt.tight_layout()
    save(fig, outdir, "5_evolucao_todos_grupos.png")


